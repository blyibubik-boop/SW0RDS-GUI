-- Dragging functionality
local UserInputService = game:GetService("UserInputService")
local dragging = false
local dragInput, dragStart, startPos

local function updateInput(input)
    local delta = input.Position - dragStart
    mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position

        local connection
        connection = input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                connection:Disconnect()
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input == dragInput) then
        updateInput(input)
    end
end)

-- Button Functions
local function updateOutput(text, isError)
    outputLabel.Text = text
    if isError then
        outputLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    else
        outputLabel.TextColor3 = Color3.fromRGB(0, 150, 0)
    end
    task.wait(3)
    outputLabel.Text = "[Output] SW0RDS Loadstring Executor ready."
    outputLabel.TextColor3 = Color3.fromRGB(0, 0, 0)
end

clearBtn.MouseButton1Click:Connect(function()
    scriptBox.Text = ""
    updateOutput("Script cleared", false)
end)

executeBtn.MouseButton1Click:Connect(function()
    local scriptText = scriptBox.Text
    if scriptText == "" then
        updateOutput("Error: No script entered!", true)
        return
    end
    
    updateOutput("Executing script...", false)
    
    local success, err = pcall(function()
        -- Check if it's a loadstring or raw script
        if scriptText:match("loadstring") then
            -- Execute loadstring directly
            local func = loadstring(scriptText)
            if func then
                func()
            else
                error("Invalid loadstring syntax")
            end
        else
            -- Execute as normal Lua
            local func = loadstring(scriptText)
            if func then
                func()
            else
                error("Invalid script syntax")
            end
        end
    end)
    
    if success then
        updateOutput("Script executed successfully!", false)
    else
        updateOutput("Error: " .. tostring(err), true)
    end
end)

injectBtn.MouseButton1Click:Connect(function()
    updateOutput("Injector ready - Use Execute button to run scripts", false)
end)

